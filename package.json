    "@sentry/node": "^10.59.0",
    "@supabase/supabase-js": "^2.84.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "chrono-node": "^2.9.1",
    "discord.js": "^14.24.2",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "lucide-react": "^0.556.0",
